{
  "name": "quill-claude-extension",
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "socket:dev": "node ./scripts/generate-socket-config.mjs --mode dev",
    "socket:prod": "node ./scripts/generate-socket-config.mjs --mode prod",
    "manifest:dev": "node ./scripts/generate-manifest.mjs --mode dev",
    "manifest:prod": "node ./scripts/generate-manifest.mjs --mode prod",
    "build:ts": "tsc -p tsconfig.json",
    "build:mcpb": "mcpb pack",
    "copy:mcpb": "cp ./extension.mcpb ../../app/assets/claude/quill.mcpb",
    "build:dev": "npm run clean && npm run socket:dev && npm run manifest:dev && npm run build:ts && npm run build:mcpb && npm run copy:mcpb",
    "build:prod": "npm run clean && npm run socket:prod && npm run manifest:prod && npm run build:ts && npm run build:mcpb && npm run copy:mcpb",
    "build": "npm run build:prod",
    "version:bump": "node ./scripts/bump-version.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.1.1",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.2"
  }
}
